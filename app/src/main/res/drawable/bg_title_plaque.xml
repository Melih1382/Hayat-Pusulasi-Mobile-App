<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp"/>
            <solid android:color="#2D1F17"/> <stroke android:width="3dp" android:color="@color/royal_border"/> </shape>
    </item>

    <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <stroke android:width="1dp" android:color="#5D4037"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>
</layer-list>