<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp"/>
            <solid android:color="#40000000"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="4dp"/> <gradient
            android:startColor="#3E2723"
            android:centerColor="#5D4037"
            android:endColor="#3E2723"
            android:angle="90"/> <stroke android:width="1dp" android:color="#261815"/> </shape>
    </item>

    <item android:left="8dp" android:width="6dp" android:height="6dp" android:gravity="center_vertical|left">
        <shape android:shape="oval"><solid android:color="@color/iron_rust"/></shape>
    </item>
    <item android:right="8dp" android:width="6dp" android:height="6dp" android:gravity="center_vertical|right">
        <shape android:shape="oval"><solid android:color="@color/iron_rust"/></shape>
    </item>

</layer-list>