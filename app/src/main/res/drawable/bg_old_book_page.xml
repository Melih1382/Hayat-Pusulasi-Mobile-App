<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3E2723"/> </shape>
    </item>

    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#CBB695"
                android:centerColor="#E6D7BC"
                android:endColor="#CBB695"
                android:angle="90"
                android:type="linear"/>
            <corners android:radius="2dp"/>
        </shape>
    </item>

    <item android:top="8dp" android:left="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#F2E8D5"/> <stroke android:width="1dp" android:color="#D4C5A5"/>
        </shape>
    </item>
</layer-list>