<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mystic_gradient">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KAHİNİN GÖZÜ"
        android:textColor="@color/rusticGold"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:fontFamily="serif"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <FrameLayout
        android:id="@+id/compassContainer"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_glow_circle"
            android:alpha="0.2"/>

        <ImageView
            android:id="@+id/imgCompassBase"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_mystic_compass_base"/>

        <ImageView
            android:id="@+id/imgCompassNeedle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_mystic_compass_needle"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tvOracleResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Kaderini sormaya cesaretin var mı?"
        android:textColor="@color/rusticParchment"
        android:textSize="20sp"
        android:textAlignment="center"
        android:fontFamily="serif"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/compassContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Seçenekleri yaz (Virgülle ayır)"
        app:hintTextColor="#BCAAA4"
        app:boxStrokeColor="@color/rusticGold"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btnAskOracle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etOracleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/rusticParchment"
            android:background="@color/rusticInputBg"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnAskOracle"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="KADER ÇARKINI ÇEVİR"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#EFEBE9"
        android:backgroundTint="@color/rusticButton"
        app:cornerRadius="12dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>