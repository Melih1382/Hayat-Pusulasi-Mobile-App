<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_quest_scroll">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingTop="16dp"
        android:paddingBottom="80dp"> <!-- Added bottom padding for FAB space -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kralın Emirleri"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#3E2723" 
            android:fontFamily="serif"
            android:layout_gravity="center"
            android:layout_marginTop="85dp"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvQuests"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnAddQuest"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@drawable/ic_plus_gold" 
        android:background="@drawable/bg_btn_add_seal"
        android:scaleType="centerInside"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:elevation="12dp"
        android:contentDescription="Yeni Görev Ekle"/>

</FrameLayout>