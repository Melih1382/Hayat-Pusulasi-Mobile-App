<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_main"
        android:contentDescription="Background"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000" />

    <LinearLayout
        android:id="@+id/mainMenuContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="50dp">

        <FrameLayout
            android:id="@+id/layoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"> <View
            android:layout_width="280dp"
            android:layout_height="70dp"
            android:background="@drawable/bg_rustic_sign"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="serif"
                android:text="HAYAT PUSULASI"
                android:textColor="#EFEBE9"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </FrameLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMenuJournal"
            android:layout_width="260dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_peasant_button"
            android:text="GÜNLÜK"
            android:textColor="#EFEBE9"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMenuQuests"
            android:layout_width="260dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_peasant_button"
            android:text="GÖREVLER"
            android:textColor="#EFEBE9"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMenuStats"
            android:layout_width="260dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_peasant_button"
            android:text="ARŞİV"
            android:textColor="#EFEBE9"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnMenuOracle"
            android:layout_width="260dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_peasant_button"
            android:text="KAHİN"
            android:textColor="#EFEBE9"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:stateListAnimator="@null"/>

        <FrameLayout
            android:id="@+id/layoutQuote"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_quote_panel"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvDailyQuote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="..."
                android:textColor="#BCAAA4"
                android:textSize="14sp"
                android:textStyle="italic"/>
        </FrameLayout>

        <ImageButton
            android:id="@+id/btnLogout"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"

            android:background="@drawable/bg_peasant_button"

            android:src="@drawable/ic_dungeon_door"
            app:tint="#EFEBE9"

            android:padding="14dp"
            android:scaleType="fitCenter"
            android:contentDescription="Çıkış Yap - Kapı"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"
        android:text="v1.1"
        android:textColor="#BCAAA4"
        android:fontFamily="serif"
        android:textSize="12sp"/>

</RelativeLayout>